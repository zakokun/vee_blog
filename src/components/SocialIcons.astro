---
import { SITE_DATA } from '../constants';

interface Props {
  size?: number;
  gap?: string;
  class?: string;
  twitter?: string;
  x?: string;
  bluesky?: string;
  linkedin?: string;
  github?: string;
  scholar?: string;
  email?: string;
}

const {
  size = 24,
  gap = "1.5rem",
  class: className,
  twitter = SITE_DATA.twitter,
  x = SITE_DATA.x,
  bluesky = SITE_DATA.bluesky,
  linkedin = SITE_DATA.linkedin,
  github = SITE_DATA.github,
  scholar = SITE_DATA.scholar,
  email = SITE_DATA.email
} = Astro.props;
---

<div class:list={["social-icons", className]} style={{ gap }}>
  {twitter && (
    <a href={`https://twitter.com/${twitter}`} aria-label="Twitter" target="_blank" rel="noopener noreferrer">
      <svg viewBox="0 0 24 24" width={size} height={size} fill="currentColor">
        <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"></path>
      </svg>
    </a>
  )}
  {x && (
    <a href={`https://x.com/${x}`} aria-label="X" target="_blank" rel="noopener noreferrer">
      <svg viewBox="0 0 24 24" width={size} height={size} fill="currentColor">
        <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"></path>
      </svg>
    </a>
  )}
  {bluesky && (
    <a href={`https://bsky.app/profile/${bluesky}`} aria-label="Bluesky" target="_blank" rel="noopener noreferrer">
      <svg viewBox="0 0 24 24" width={size} height={size} fill="currentColor">
        <path d="M12 10.8c-1.087-2.114-4.046-6.053-6.798-7.995C2.566.944 1.561 1.266.902 1.565.139 1.908 0 3.08 0 3.768c0 .69.378 5.65.624 6.479.815 2.736 3.713 3.66 6.383 3.364.136-.02.275-.039.415-.056-.138.022-.276.04-.415.056-3.912.58-7.387 2.005-2.83 7.078 5.013 5.19 6.87-1.113 7.823-4.308.953 3.195 2.05 9.271 7.733 4.308 4.267-4.308 1.172-6.498-2.74-7.078a8.741 8.741 0 0 1-.415-.056c.14.017.279.036.415.056 2.67.297 5.568-.628 6.383-3.364.246-.828.624-5.79.624-6.478 0-.69-.139-1.861-.902-2.204-.659-.299-1.664-.621-4.3 1.24C16.046 4.748 13.087 8.687 12 10.8Z"></path>
      </svg>
    </a>
  )}
  {linkedin && (
    <a href={`https://linkedin.com/in/${linkedin}`} aria-label="LinkedIn" target="_blank" rel="noopener noreferrer">
      <svg viewBox="0 0 24 24" width={size} height={size} fill="currentColor">
        <path d="M20.5 2h-17A1.5 1.5 0 002 3.5v17A1.5 1.5 0 003.5 22h17a1.5 1.5 0 001.5-1.5v-17A1.5 1.5 0 0020.5 2zM8 19H5v-9h3zM6.5 8.25a1.75 1.75 0 110-3.5 1.75 1.75 0 010 3.5zM19 19h-3v-4.74c0-1.42-.6-1.93-1.38-1.93A1.74 1.74 0 0013 14.19V19h-3v-9h2.9v1.3a3.11 3.11 0 012.7-1.4c1.55 0 3.4 1.08 3.4 3.93z"></path>
      </svg>
    </a>
  )}
  {github && (
    <a href={`https://github.com/${github}`} aria-label="GitHub" target="_blank" rel="noopener noreferrer">
      <svg viewBox="0 0 24 24" width={size} height={size} fill="currentColor">
        <path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.868-.013-1.703-2.782.604-3.369-1.342-3.369-1.342-.454-1.154-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.579.688.481C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"></path>
      </svg>
    </a>
  )}
  {scholar && (
    <a href={`https://scholar.google.com/citations?user=${scholar}`} aria-label="Google Scholar" target="_blank" rel="noopener noreferrer">
      <svg viewBox="0 0 24 24" width={size} height={size} fill="currentColor">
        <path d="M12 2L1 7l11 5 9-4.09V17h2V7L12 2z"></path>
        <path d="M19 11v6c0 1.66-3.13 3-7 3s-7-1.34-7-3v-6l7 3 7-3z"></path>
      </svg>
    </a>
  )}
  {email && (
    <a href={`mailto:${email}`} aria-label="Email">
      <svg viewBox="0 0 24 24" width={size} height={size} fill="currentColor">
        <path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"></path>
      </svg>
    </a>
  )}
</div>
