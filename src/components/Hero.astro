---
import SocialIcons from './SocialIcons.astro';
import portraitImage from '../assets/homepage-photo.jpeg';
const { name, tagline, twitter, linkedin, scholar, email } = Astro.props;
---

<section class="hero">
  <div class="hero-content">
    <div class="portrait-container">
      <img
        src={portraitImage.src}
        width={portraitImage.width}
        height={portraitImage.height}
        alt={name}
        class="portrait"
        loading="eager"
        decoding="async"
      />
    </div>
    <div class="hero-text">
      <h1>{name}</h1>
      <p class="tagline">{tagline}</p>
      <SocialIcons 
        size={40}
        gap=1.5
        twitter={twitter} 
        linkedin={linkedin} 
        scholar={scholar} 
        email={email} 
      />
    </div>
  </div>
</section>
